# Streamlit Cloud Secrets
# Copy this file and fill in your real keys.
# WARNING: Never commit this file with real values!
# On Streamlit Cloud, add these via the app dashboard:
#   https://share.streamlit.io/ -> Your app -> Settings -> Secrets

GOOGLE_API_KEY = "your_google_api_key_here"
PINECONE_API_KEY = "your_pinecone_api_key_here"
PINECONE_ENVIRONMENT = "your_pinecone_environment_here"
PINECONE_INDEX_NAME = "resume-qa"
